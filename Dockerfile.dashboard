FROM node:22-alpine

WORKDIR /app

COPY dashboard/package*.json ./
RUN npm install --production

COPY dashboard/server.js ./
COPY dashboard/index.html ./

# Mount these at runtime via docker-compose volumes
# /app/memory, /app/economy, /app/symphony

ENV PORT=4200
ENV ZHC_ROOT=/zhc

EXPOSE 4200

CMD ["node", "server.js"]

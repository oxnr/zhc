# ============================================
# Zero Human Corp — Environment Configuration
# ============================================

# === Model Access (Off-Mode / Subscription) ===
# We use CLI tools from subscriptions, NOT raw API keys

# Claude Code CLI path (comes with Claude Max subscription)
CLAUDE_CODE_PATH=claude
# Default model for planning/reasoning agents
CLAUDE_MODEL=claude-opus-4-6

# Codex CLI path (comes with ChatGPT Pro subscription)
CODEX_CLI_PATH=codex
# Default model for coding agents
CODEX_MODEL=gpt-5.3-codex

# === OpenClaw Gateway ===
OPENCLAW_HOME=./
OPENCLAW_GATEWAY_PORT=3001

# === Dashboard (Mission Control) ===
DASHBOARD_PORT=4200
DASHBOARD_DB_PATH=./dashboard/mission-control.db

# === Agent Limits ===
MAX_SPAWN_DEPTH=2          # CEO -> Lead -> Worker (2 levels)
MAX_CHILDREN_PER_AGENT=5   # Max 5 sub-agents per parent
CEO_HEARTBEAT_INTERVAL=300 # CEO checks in every 5 minutes ($200 Max tier = plenty of headroom)

# === Economic Tracking ===
STARTING_CAPITAL=0          # We start at $0, must earn everything
DAILY_BUDGET_LIMIT=50       # Safety cap: max $50/day spend on any external services
REVENUE_LOG_PATH=./memory/revenue-log.md

# === Channels (pick what you use) ===
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
DISCORD_BOT_TOKEN=

# === External Services (agents can use these) ===
GITHUB_TOKEN=               # For CTO to create/manage repos (PAT with repo scope)
GITHUB_SSH_KEY_PATH=~/.ssh/zhc_deploy  # SSH key for git push (generated by setup.sh)
STRIPE_SECRET_KEY=          # For payment processing (sk_test_ for dev, sk_live_ for prod)

# === Cloudflare (Primary Deploy Target) ===
CLOUDFLARE_ACCOUNT_ID=      # From: https://dash.cloudflare.com → Account ID (right sidebar)
CLOUDFLARE_API_TOKEN=       # From: https://dash.cloudflare.com/profile/api-tokens → Create Token → "Edit Cloudflare Workers"
CLOUDFLARE_ZONE_ID=         # Optional: only if using a custom domain (from domain dashboard)
CF_PAGES_PROJECT_PREFIX=zhc # Prefix for auto-created Cloudflare Pages projects

# === Daily Summary Email (Optional) ===
SUMMARY_EMAIL=              # Where to send daily summaries (your email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                  # Gmail address or SMTP username
SMTP_PASS=                  # Gmail app password or SMTP password
